<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <!--    Joshua added these-->
    <uses-permission android:name="android.permission.AUTOFILL" />
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:label="Pcrypt"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        tools:ignore="GoogleAppIndexingWarning">
        <activity
            android:name=".MainActivity"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <meta-data
                android:name="io.flutter.embedding.android.SplashScreenDrawable"
                android:resource="@drawable/launch_background" />
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <meta-data
                android:name="flutterEmbedding"
                android:value="2" />

        </activity>

        <activity
            android:name=".SavePasswordActivity"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:excludeFromRecents="true"
            android:exported="true">
            <meta-data
                android:name="io.flutter.embedding.android.SplashScreenDrawable"
                android:resource="@drawable/launch_background" />
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <meta-data
                android:name="flutterEmbedding"
                android:value="2" />

        </activity>


        <activity
            android:name=".AutofillActivity"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:exported="true">

            <meta-data
                android:name="io.flutter.embedding.android.SplashScreenDrawable"
                android:resource="@drawable/launch_background" />
            <meta-data
                android:name="android.autofill"
                android:value="org.pcrypt.app2/.AutofillActivity" />
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <meta-data
                android:name="flutterEmbedding"
                android:value="2" />

            <intent-filter>
                <action android:name="android.service.autofill.AutofillService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="com.keevault.flutter_autofill_service.ACTIVITY_NAME"
            android:value="org.pcrypt.app2.AutofillActivity" />
        <meta-data
            android:name="com.keevault.flutter_autofill_service.SAVE_ACTIVITY_NAME"
            android:value="org.pcrypt.app2.SavePasswordActivity" />
        <meta-data
            android:name="com.keevault.flutter_autofill_service.match_header_drawable_name"
            android:value="logo" />
        <!--        <meta-data-->
        <!--            android:name="com.keevault.flutter_autofill_service.select_another_entry"-->
        <!--            android:value="More entries" />-->
        <service
            android:name="com.keevault.flutter_autofill_service.FlutterAutofillService"
            tools:replace="label"
            android:label="Pcrypt"
            android:permission="android.permission.BIND_AUTOFILL_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.autofill.AutofillService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <meta-data
                android:name="android.autofill"
                android:value="org.pcrypt.app2/com.keevault.flutter_autofill_service.FlutterAutofillService" />

            <meta-data
                android:name="com.keevault.flutter_autofill_service.unlock_label"
                android:value="Pcrypt" />
            <!-- Override default unlock icon with meta-data like below -->
            <meta-data
                android:name="com.keevault.flutter_autofill_service.unlock_drawable_name"
                android:value="logo" />
            <!--            JOSHUA ADDED THIS PART BELOW-->
            <meta-data
                android:name="android.service.autofill.theme"
                android:resource="@style/AutofillTheme" />
            <!--            JOSHUA BLOCK ENDED-->
        </service>

    </application>
    <!-- Provide required visibility configuration for API level 30 and above -->
    <queries>
        <!-- If your app checks for SMS support -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="sms" />
        </intent>
        <!-- If your app checks for call support -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="tel" />
        </intent>
    </queries>
</manifest>
